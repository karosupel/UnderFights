  m_Script: {fileID: 11500000, guid: 4b8867809c73bf64c883ce15298e632e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  DialogueLines:
  - Welcome! You must be new here (press F to continue)
  - Don't worry. I'll teach you how to fight
  - You're in the Main Panel now. Check out all these buttons at the bottom of the
    screen
  - When you press the Fight button, you will activate a quick time event to damage
    the enemy
  - When you press Check, you'll check the enemy stats
  - When you pres Item, you can use Items in your inventory to heal yourself up
  - Check everything out and when you're ready - attack!
  - Congrats! You've succesfully damaged the enemy
  - Now you've entered fight zone
  - Here the enemy will try to attack you
  - Try to dodge all of the attacks!
  - Now... the real fight begins
  continuePressed: 0
